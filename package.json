{
  "name": "click-game",
  "version": "0.1.0",
  "description": "Click Game",
  "keywords": [
    "click",
    "game",
    "money",
    "server"
  ],
  "license": "MIT",
  "author": "Kevin",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently --raw 'npm run watch:ts' 'npm run watch:bundle'",
    "bundle": "esbuild scripts/main.ts --bundle --outfile=public/scripts/main.js --format=iife --sourcemap=inline",
    "build": "tsc && npm run bundle",
    "start": "http-server public",
    "watch:ts": "tsc -w --preserveWatchOutput",
    "watch:bundle": "npm run bundle -- --watch"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "http-server": "^14.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eruda": "^3.4.3",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
